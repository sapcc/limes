# HELP limitas_rate_default_limit The value of the default limit per project for this rate. Projects using this default rate limit may not exceed more than this amount of operations or units over the course of the respective time window (see limitas_rate_default_window_seconds).
# TYPE limitas_rate_default_limit gauge
limitas_rate_default_limit{rate="rateWithProjectLimit",service="unittest"} 50
# HELP limitas_rate_default_window_seconds The window for the default limit per project for this rate. Projects using this default rate limit may spend their limit (see limitas_rate_default_limit) over the course of this many seconds.
# TYPE limitas_rate_default_window_seconds gauge
limitas_rate_default_window_seconds{rate="rateWithProjectLimit",service="unittest"} 1
# HELP limitas_rate_info Info metric for rates. The value is always 1, and information can be found in labels. The "has_limit" label refers to whether there is a rate limit on the project level. There may also be a global rate limit that is shared by all projects (see limitas_cluster_rate_global_limit).
# TYPE limitas_rate_info gauge
limitas_rate_info{category="unittest",display_name="Cluster-Limited Rate",has_limit="false",has_usage="false",rate="rateWithClusterLimit",service="unittest",topology="flat",unit=""} 1
limitas_rate_info{category="unittest",display_name="First Rate",has_limit="false",has_usage="true",rate="firstrate",service="unittest",topology="flat",unit=""} 1
limitas_rate_info{category="unittest",display_name="Project-Limited Rate",has_limit="true",has_usage="false",rate="rateWithProjectLimit",service="unittest",topology="flat",unit=""} 1
limitas_rate_info{category="unittest",display_name="Second Rate",has_limit="false",has_usage="true",rate="secondrate",service="unittest",topology="flat",unit="KiB"} 1
limitas_rate_info{category="unittest",display_name="X Another Rate",has_limit="false",has_usage="false",rate="xAnotherRate",service="unittest",topology="flat",unit=""} 1
