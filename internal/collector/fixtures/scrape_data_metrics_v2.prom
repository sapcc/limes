# HELP limitas_cluster_rate_global_limit The value of the global limit for this rate. All users together may not exceed more than this amount of operations or units over the course of the respective time window (see limitas_cluster_rate_global_window_seconds). Only shown for rates that have limits (not for those that just track usage).
# TYPE limitas_cluster_rate_global_limit gauge
limitas_cluster_rate_global_limit{rate="rateWithClusterLimit",service="unittest"} 5000
# HELP limitas_cluster_rate_global_window_seconds The window for the global limit for this rate. All users together may spend their limit (see limitas_cluster_rate_global_limit) over the course of this many seconds. Only shown for rates that have limits (not for those that just track usage).
# TYPE limitas_cluster_rate_global_window_seconds gauge
limitas_cluster_rate_global_window_seconds{rate="rateWithClusterLimit",service="unittest"} 1
# HELP limitas_cluster_resource_capacity Capacity for resources, split by availability zone (AZ). If an overcommit factor is configured, this will differ from the raw capacity accordingly.
# TYPE limitas_cluster_resource_capacity gauge
limitas_cluster_resource_capacity{az="az-one",resource="capacity",service="unittest"} 0
limitas_cluster_resource_capacity{az="az-one",resource="things",service="unittest"} 0
limitas_cluster_resource_capacity{az="az-two",resource="capacity",service="unittest"} 0
limitas_cluster_resource_capacity{az="az-two",resource="things",service="unittest"} 0
limitas_cluster_resource_capacity{az="unknown",resource="capacity",service="unittest"} 1234
# HELP limitas_cluster_resource_raw_capacity Raw capacity for resources (i.e. without considering overcommit), split by availability zone (AZ).
# TYPE limitas_cluster_resource_raw_capacity gauge
limitas_cluster_resource_raw_capacity{az="az-one",resource="capacity",service="unittest"} 0
limitas_cluster_resource_raw_capacity{az="az-one",resource="things",service="unittest"} 0
limitas_cluster_resource_raw_capacity{az="az-two",resource="capacity",service="unittest"} 0
limitas_cluster_resource_raw_capacity{az="az-two",resource="things",service="unittest"} 0
limitas_cluster_resource_raw_capacity{az="unknown",resource="capacity",service="unittest"} 617
# HELP limitas_project_rate_limit For each project and rate, the value of the current rate limit. The respective project may not exceed more than this amount of operations or units over the course of the respective time window (see limitas_project_rate_window_seconds). Only shown for rates that have limits (not for those that just track usage).
# TYPE limitas_project_rate_limit gauge
limitas_project_rate_limit{az="any",domain="germany",domain_id="uuid-for-germany",project="berlin",project_id="uuid-for-berlin",rate="rateWithProjectLimit",service="unittest"} 50
limitas_project_rate_limit{az="any",domain="germany",domain_id="uuid-for-germany",project="dresden",project_id="uuid-for-dresden",rate="rateWithProjectLimit",service="unittest"} 50
